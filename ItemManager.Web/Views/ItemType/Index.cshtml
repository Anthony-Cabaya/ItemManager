@model IEnumerable<ItemType>
@{
    ViewData["Title"] = "Item Types";
}
<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Item Types</h2>
        <a asp-controller="ItemType" asp-action="Create" class="btn btn-primary">
            Create New
        </a>
    </div>
    @* Search Box *@
    <div class="mb-3">
        <input type="text"
               id="searchInput"
               class="form-control"
               placeholder="Search by name or sort order..." />
    </div>
    <table class="table table-bordered table-hover" id="itemTypeTable">
        <thead>
            <tr>
                <th>
                    Item Type Name
                    <span class="sort-btn ms-1" data-col="0" data-dir="asc"
                          style="cursor:pointer;" title="Sort A→Z">▲</span>
                    <span class="sort-btn ms-1" data-col="0" data-dir="desc"
                          style="cursor:pointer;" title="Sort Z→A">▼</span>
                </th>
                <th>
                    Sort Order
                    <span class="sort-btn ms-1" data-col="1" data-dir="asc"
                          style="cursor:pointer;" title="Ascending">▲</span>
                    <span class="sort-btn ms-1" data-col="1" data-dir="desc"
                          style="cursor:pointer;" title="Descending">▼</span>
                </th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody id="itemTypeBody">
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ItemTypeName</td>
                    <td>@item.Sort</td>
                    <td>
                        <a asp-controller="ItemType"
                           asp-action="Edit"
                           asp-route-id="@item.ItemTypeID"
                           class="btn btn-sm btn-warning">
                            Edit
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<style>
    .sort-btn {
        cursor: pointer;
        opacity: 0.4;
    }
    .sort-btn.active {
        color: #0d6efd;
        font-weight: bold;
        opacity: 1;
    }
</style>

@section Scripts {
    <script>
        const tbody = document.getElementById('itemTypeBody');
        const originalRows = Array.from(tbody.querySelectorAll('tr'));

        // SEARCH
        document.getElementById('searchInput').addEventListener('input', function () {
            const search = this.value.toLowerCase();
            const rows = Array.from(tbody.querySelectorAll('tr'));

            rows.forEach(row => {
                const name = row.cells[0].textContent.toLowerCase();
                const sort = row.cells[1].textContent.toLowerCase();

                row.style.display = (name.includes(search) || sort.includes(search))
                    ? ''
                    : 'none';
            });
        });

        // Sort with Toggle
        document.querySelectorAll('.sort-btn').forEach(btn => {
            btn.addEventListener('click', function () {

                const col = parseInt(this.dataset.col);
                const dir = this.dataset.dir;
                const isActive = this.classList.toggle('active');

                // Remove active from all other buttons in the same column
                document.querySelectorAll(`.sort-btn[data-col='${col}']`).forEach(b => {
                    if (b !== this) b.classList.remove('active');
                });

                if (!isActive) {
                    originalRows.forEach(row => tbody.appendChild(row));
                    return;
                }

                const rows = Array.from(tbody.querySelectorAll('tr'));

                rows.sort((a, b) => {
                    const aText = a.cells[col].textContent.trim();
                    const bText = b.cells[col].textContent.trim();
                    const aVal = isNaN(aText) ? aText.toLowerCase() : parseFloat(aText);
                    const bVal = isNaN(bText) ? bText.toLowerCase() : parseFloat(bText);

                    if (aVal < bVal) return dir === 'asc' ? -1 : 1;
                    if (aVal > bVal) return dir === 'asc' ? 1 : -1;
                    return 0;
                });

                rows.forEach(row => tbody.appendChild(row));
            });
        });
    </script>
}