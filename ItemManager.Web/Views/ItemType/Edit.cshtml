@model ItemManager.Web.ViewModels.ItemTypeViewModel

@{
    ViewData["Title"] = "Edit Item Type";
}

<div class="container mt-4">
    <h2>Edit Item Type</h2>

    <form asp-action="Edit" method="post">
        <!-- Hidden field for ID -->
        <input asp-for="ItemTypeID" type="hidden" />

        <div class="mb-3">
            <label asp-for="ItemTypeName" class="form-label"></label>
            <input asp-for="ItemTypeName" class="form-control" />
            <span asp-validation-for="ItemTypeName" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Sort" class="form-label"></label>
            <input asp-for="Sort" class="form-control" />
            <span asp-validation-for="Sort" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-success">Save Changes</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Back</a>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
