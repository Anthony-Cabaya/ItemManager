@{
    ViewData["Title"] = "Error";
}
<div class="container mt-4">
    <div class="alert alert-danger">
        <h4>Something went wrong!</h4>
        <p>@ViewData["ErrorMessage"]</p>
    </div>
    <a asp-controller="Dashboard"
       asp-action="Index"
       class="btn btn-primary">
        Go to Dashboard
    </a>
</div>
