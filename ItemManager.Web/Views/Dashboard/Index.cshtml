@{
    ViewData["Title"] = "Dashboard";
}
<div class="container mt-4">
    <h2>Welcome to Item Manager</h2>
    <p class="text-muted">Select an option below to get started.</p>
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Item Types</h5>
                    <p class="card-text">Manage your item categories.</p>
                    <a asp-controller="ItemType"
                       asp-action="Index"
                       class="btn btn-primary">
                        Go to Item Types
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title">Items</h5>
                    <p class="card-text">Manage your items.</p>
                    <a asp-controller="Item"
                       asp-action="Index"
                       class="btn btn-primary">
                        Go to Items
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
